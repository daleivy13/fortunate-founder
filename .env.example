# ── PoolPal AI — Environment Variables ────────────────────────────────────────
# Copy to .env.local and fill in your values. Never commit .env.local to git.

# ── Database (Neon Postgres) ───────────────────────────────────────────────────
# Get from: https://neon.tech → New Project → Connection string
DATABASE_URL=postgresql://user:password@host/poolpal?sslmode=require

# ── Firebase Auth ─────────────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your Apps → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server-side) — Service Account JSON fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Stripe Price IDs — create in Stripe Dashboard → Products
STRIPE_PRICE_SMALL=price_small_monthly     # $200/mo
STRIPE_PRICE_MEDIUM=price_medium_monthly   # $500/mo
STRIPE_PRICE_LARGE=price_large_monthly     # $1200/mo

# ── Google Maps (GPS/Routes) ──────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Anthropic (AI Chemistry) ──────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Weather Intelligence (OpenWeatherMap) ─────────────────────────────────────
# Get from: https://openweathermap.org/api → Sign up → API keys
# Free tier: 1,000 calls/day — enough for ~333 pools/day
# One Call API 3.0 gives temp, UV index, rain, wind, alerts, 7-day forecast
OPENWEATHER_API_KEY=

# ── Revolut Business — Multi-Currency Stripe Payout Accounts ─────────────────
# Step 1: Open Revolut Business at business.revolut.com
# Step 2: Open currency accounts for USD, GBP, EUR, AUD (each has its own IBAN/account number)
# Step 3: In Stripe Dashboard → Settings → Payouts → Add bank account
#         Add each Revolut currency account separately
#         Stripe gives each a bank account ID like "ba_1ABC..."
# Step 4: Paste those IDs here
REVOLUT_STRIPE_ACCOUNT_USD=ba_
REVOLUT_STRIPE_ACCOUNT_GBP=ba_
REVOLUT_STRIPE_ACCOUNT_EUR=ba_
REVOLUT_STRIPE_ACCOUNT_AUD=ba_
REVOLUT_STRIPE_ACCOUNT_CAD=ba_

# ── Stripe Prices — Multi-Currency ────────────────────────────────────────────
# In Stripe Dashboard → Products → PoolPal Solo/Growth/Enterprise
# Click each product → Add price → choose currency → set amount → copy Price ID
# You need one price per currency per plan
STRIPE_PRICE_SOLO_USD=price_
STRIPE_PRICE_SOLO_GBP=price_
STRIPE_PRICE_SOLO_EUR=price_
STRIPE_PRICE_SOLO_AUD=price_
STRIPE_PRICE_GROWTH_USD=price_
STRIPE_PRICE_GROWTH_GBP=price_
STRIPE_PRICE_GROWTH_EUR=price_
STRIPE_PRICE_GROWTH_AUD=price_
STRIPE_PRICE_ENT_USD=price_
STRIPE_PRICE_ENT_GBP=price_
STRIPE_PRICE_ENT_EUR=price_
STRIPE_PRICE_ENT_AUD=price_

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys → Create Key
RESEND_API_KEY=re_
